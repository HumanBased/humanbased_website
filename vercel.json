{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/basedtalk", "destination": "https://basedtalk-website.vercel.app/basedtalk" },
    { "source": "/basedtalk/:path*", "destination": "https://basedtalk-website.vercel.app/basedtalk/:path*" },
    { "source": "/apps/basedtalk", "destination": "https://basedtalk-website.vercel.app/basedtalk" },
    { "source": "/apps/basedtalk/:path*", "destination": "https://basedtalk-website.vercel.app/basedtalk/:path*" },
    { "source": "/((?!.*\\.).*)", "destination": "/index.html" }
  ]
}
